{
  "name": "lizheng.me",
  "version": "1.0.0",
  "description": "Personal homepage of Zheng Li",
  "type": "module",
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "gate:g1": "bun run typecheck && bun run lint:check",
    "gate:g2": "bun run scripts/gate-security.ts",
    "gate:l1": "bun run scripts/check-coverage.ts",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nocoo/lizheng.me.git"
  },
  "author": "Zheng Li",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nocoo/lizheng.me/issues"
  },
  "homepage": "https://github.com/nocoo/lizheng.me#readme",
  "dependencies": {
    "lucide-react": "^1.7.0",
    "next-intl": "^4.9.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vinext": "^0.0.39"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-rsc": "^0.5.22",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.27",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.5",
    "vitest": "^4.1.2"
  }
}
